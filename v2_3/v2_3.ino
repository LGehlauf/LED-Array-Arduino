struct Button {
  uint8_t pin;
  uint8_t mode;  //determined by how often button was pressed
  bool stateNew;
  bool stateOld;
};

struct LightValues {
  float r;
  float g;
  float b;
  uint8_t h;  //brightness -> german "Helligkeit"
};

struct Button button1 {
  5, 0, false, false
};  //0 = off, 3 = rainbow, 
struct Button button2 {
  6, 3, false, false
};  //starts with mode 3 = brightness offset 13 at brightnessTable[3]
struct Button button3 {
  7, 0, false, false
};

struct LightValues lv {
  0, 0, 0, 0
};

const int8_t colorTable[27] = { 0, 0, 0, 0, 0, 0, 6, 0, 0, 0, 6, 0, 0, 0, 6, 3, 3, 0, 0, 3, 3, 3, 0, 3, 2, 2, 2 };
const uint8_t brightnessTable[6] = { 4, 7, 13, 21, 30, 42 };

const uint8_t NUMPIXELS = 146;  //amount of LEDs
const uint8_t LEDPIN = 12;      //LED pin
const uint8_t MICPIN = 4;
Adafruit_NeoPixel pixels = Adafruit_NeoPixel(NUMPIXELS, LEDPIN, NEO_GRB + NEO_KHZ800);

const unsigned long ProgramDuration = 5000;  //in microseconds

void setup() {
  //Serial.begin(9600);
  //delay(1000);
  pinMode(LEDPIN, OUTPUT);
  pinMode(button1.pin, INPUT);
  pinMode(button2.pin, INPUT);
  pinMode(button3.pin, INPUT);
  pixels.begin();
  lv.r = colorTable[0 + button1.mode];
  lv.g = colorTable[1 + button1.mode];
  lv.b = colorTable[2 + button1.mode];
  lv.h = brightnessTable[button2.mode];
  setAllPixelColor(lv.r, lv.g, lv.b, lv.h);
  pixels.show();

