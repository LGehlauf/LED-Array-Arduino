void loop() {
  PTester();
  
}

void PTester(){
  unsigned long startTime = micros();

  // Rainbow iteration
  static uint16_t RainbowIterator = 0;
  RainbowIterator = (RainbowIterator + 1) % RainbowArrLength;
  // if (RainbowIterator > RainbowArrLength) RainbowIterator = 0;

  pixels.show();
  button1.stateNew = digitalRead(7);
  button2.stateNew = digitalRead(6);
  button3.stateNew = digitalRead(5);

  //button 1, change led color
  if ((button1.stateNew != button1.stateOld) && button1.stateNew) {
    button1.mode = (button1.mode + 3) % 27;
  }
  button1.stateOld = button1.stateNew;
  if (button1.mode == 3) {
    float RainbowR_R = pgm_read_float_near(RainbowR + RainbowIterator);  // special syntax for reading from sram
    float RainbowG_G = pgm_read_float_near(RainbowG + RainbowIterator);
    float RainbowB_B = pgm_read_float_near(RainbowB + RainbowIterator);
    lv.r = RainbowR_R;
    lv.g = RainbowG_G;
    lv.b = RainbowB_B;
  } else {
    lv.r = colorTable[0 + button1.mode];
    lv.g = colorTable[1 + button1.mode];
    lv.b = colorTable[2 + button1.mode];
  }
  

  //##########################################
  //button 2, change brightness
  if ((button2.stateNew != button2.stateOld) && button2.stateNew) {
    button2.mode = (button2.mode + 1) % 6;

    lv.h = brightnessTable[button2.mode];
  }
  button2.stateOld = button2.stateNew;

  //#########################################
  //button 3, change between modes like breathing light
  if ((button3.stateNew != button3.stateOld) && button3.stateNew) {
    button3.mode = (button3.mode + 1);  // % 2 -> num of modes
    if (button3.mode == 2) button3.mode = 0;
  }
  button3.stateOld = button3.stateNew;

  uint16_t peakDetector = analogRead(MICPIN);
  static uint16_t movingMin = 0;
  //uint16_t movingMinDEBUGIGNORE = 0;
  //movingMinDEBUGIGNORE = movingMIN(peakDetector);                               // DEBUG MODE
  movingMin = movingMIN(peakDetector);
  //uint16_t outlier = abs(movingMin * 0.060);                                    // DEBUG MODE
  uint16_t outlier = abs(peakDetector - movingMin);                                               
  uint8_t flash = brightnessTable[button2.mode];
  /*Serial.print(peakDetector);
  Serial.print("\t");
  Serial.print(movingMin);
  Serial.print("\t");
  Serial.print(outlier);
  Serial.print("\t");
  */
  switch (button3.mode) {
    case 1:

      if (outlier < (movingMin * 0.065)) {
        flash = round(1.0 * flash);
      } else if (outlier < (movingMin * 0.087)) {
        flash = round(1.05 * flash);
      } else if (outlier < (movingMin * 0.12)) {
        flash = round(1.1 * flash);
      } else if (outlier < (movingMin * 0.16)) {
        flash = round(1.15 * flash);
      } else if (outlier < (movingMin * 0.21)) {
        flash = round(1.2 * flash);
      } else if (outlier < (movingMin * 0.29)) {
        flash = round(1.25 * flash);
      } else if (outlier < (movingMin * 0.38)) {
        flash = round(1.3 * flash);
      } else if (outlier < (movingMin * 0.52)) {
        flash = round(1.35 * flash);
      } else flash = round(1.4 * flash);
      if (flash > 42) flash = 42;
      setAllPixelColor(lv.r, lv.g, lv.b, flash);

      break;
    default:
      setAllPixelColor(lv.r, lv.g, lv.b, lv.h);
      break;
  }
  
    
  unsigned long PDuration = micros() - startTime;
  for (;;) {  // consumes remaining time to ensure even flow
    if (micros() - startTime >= ProgramDuration){
      break;
    }
  }
  
  //return PDuration;
} 

void setAllPixelColor(float _r, float _g, float _b, uint8_t _h) {
  uint8_t r = round(_r * _h);
  uint8_t g = round(_g * _h);
  uint8_t b = round(_b * _h);
  /*
  Serial.print(r);
  Serial.print("\t");
  Serial.print(g);
  Serial.print("\t");
  Serial.print(b);
  Serial.print("\t");
  Serial.println(_h);
  */
  for (int i = 0; i < NUMPIXELS; i++) {
    pixels.setPixelColor(i, pixels.Color(r, g, b));
  }
  return;
}

uint16_t movingMIN(uint16_t sample) {
  float movingMIN = sample;
  static uint16_t samples[100] = {2000};
  static uint8_t i = 0;
  samples[i % 100] = sample;
  i++;
  for (uint8_t j = 0; j < 100; j++) {
    if (samples[j] < movingMIN) movingMIN = samples[j];
  }
  return movingMIN;
}
